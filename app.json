{
  "expo": {
    "name": "realX",
    "slug": "reelx",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "reelx",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.reelx.app",
      "googleServicesFile": "./GoogleService-Info.plist",
      "associatedDomains": [],
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      },
      "appleTeamId": "2396PCT42P"
    },
    "android": {
      "package": "com.reelx.app",
      "versionCode": 6,
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/icon.png",
        "backgroundImage": "./assets/images/icon.png",
        "monochromeImage": "./assets/images/icon.png"
      },
      "intentFilters": [],
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-localization",
        {
          "supportedLocales": {
            "ios": [
              "en",
              "ar"
            ],
            "android": [
              "en",
              "ar"
            ]
          }
        }
      ],
      "expo-notifications",
      [
        "react-native-bottom-tabs"
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#18B852",
          "image": "./assets/images/icon.png"
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/phonk.otf",
            "./assets/fonts/poppins.ttf"
          ]
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "forceStaticLinking": [
              "RNFBAnalytics",
              "RNFBApp",
              "RNFBCrashlytics",
              "RNFBInAppMessaging",
              "RNFBInstallations",
              "RNFBPerf"
            ],
            "useFrameworks": "static"
          }
        }
      ],
      "@react-native-firebase/app",
      "@react-native-firebase/auth",
      "@react-native-community/datetimepicker",
      "expo-asset",
      "expo-image",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "supportRTl": true,
      "router": {},
      "eas": {
        "projectId": "462a3cda-e70c-4472-8637-8794ff697f77"
      }
    }
  }
}
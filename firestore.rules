rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── students collection ───────────────────────────────────────────────
    match /students/{userId} {

      // Allow a user to read their own document
      allow read: if request.auth != null && request.auth.uid == userId;

      // Allow a user to CREATE their own document (initial sign-up),
      // but they must NOT include a creatorCode field.
      allow create: if request.auth != null
        && request.auth.uid == userId
        && !('creatorCode' in request.resource.data);

      // Allow a user to UPDATE their own document, but:
      //   • they cannot set / change the creatorCode field
      //   • they cannot delete the creatorCode field that already exists
      allow update: if request.auth != null
        && request.auth.uid == userId
        && !('creatorCode' in request.resource.data.diff(resource.data).affectedKeys());
    }

    // ─── creator_codes collection ──────────────────────────────────────────
    // Managed exclusively by the admin SDK (Cloud Functions).
    // Clients may read their own code entry but never write.
    match /creator_codes/{code} {
      allow read: if request.auth != null && resource.data.uid == request.auth.uid;
      allow write: if false;
    } 

    // ─── cms collection ──────────────────────────────────────────────────
    match /cms/{docId} {
      // Allow public read for all CMS documents (banners, categories, etc.)
      allow read: if true;
      // Only admin can write to CMS
      allow write: if request.auth != null && isAdmin(request.auth.uid);
    }

    // ─── categories collection ───────────────────────────────────────────
    match /categories/{catId} {
      // Allow public read for categories
      allow read: if true;
      // Only admin can write to categories
      allow write: if request.auth != null && isAdmin(request.auth.uid);
    }

    // ─── vendors collection ──────────────────────────────────────────────
    match /vendors/{vendorId} {
      // Allow public read for vendors
      allow read: if true;
      // Only admin can write to vendors
      allow write: if request.auth != null && isAdmin(request.auth.uid);
    }

    // ─── rewards collection ──────────────────────────────────────────────
    match /rewards/{rewardId} {
      // Allow public read for rewards
      allow read: if true;
      // Only admin can write to rewards
      allow write: if request.auth != null && isAdmin(request.auth.uid);
    }

    // ─── Helper function to check for admin role ─────────────────────────
    function isAdmin(userId) {
      // Check if the user document has admin = true
      return exists(/databases/$(database)/documents/students/$(userId))
        && get(/databases/$(database)/documents/students/$(userId)).data.admin == true;
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
